#!/usr/bin/env bash
set -euo pipefail

: "${RPC_URL:?RPC_URL not set. Usage: RPC_URL=<url> PRIVATE_KEY=<key> ./deploy}"
: "${PRIVATE_KEY:?PRIVATE_KEY not set. Usage: RPC_URL=<url> PRIVATE_KEY=<key> ./deploy}"
: "${OWNER:?OWNER not set. Please set the OWNER env variable.}"

echo "Broadcasting ArbExecutor contract..."
exec forge script script/Deploy.s.sol \
  --rpc-url "$RPC_URL" \
  --private-key "$PRIVATE_KEY" \
  --broadcast
