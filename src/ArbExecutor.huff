    dup1 0x00 mstore                                  // store calls_len at mem[0x00]
    dup1 0x104 0x20 calldatacopy                      // copy packed calls to mem[0x20]
    dup1 0x20 sha3                                   // [route_hash, params_ptr, calls_ptr, num_calls]

    0xe4 calldataload                                 // [+ expected_hash]
    eq route_hash_ok jumpi
