#define macro GET_SLOT(slot) = takes (0) returns (0) {
    <slot> sload
    0x00 mstore
    0x20 0x00 return
}

#define macro ONLY_OWNER() = takes (0) returns (0) {
    0x00 sload
    caller eq is_owner jumpi
    0x82b42900 0x00 mstore
    0x04 0x1c revert
is_owner:
}

#define macro NON_REENTRANT() = takes (0) returns (0) {
    0x06 sload
    0x01 eq is_unlocked jumpi
    0x82b42900 0x00 mstore
    0x04 0x1c revert
is_unlocked:
    0x02 0x06 sstore
}

#define macro REENTRANCY_GUARD_RELEASE() = takes (0) returns (0) {
    0x01 0x06 sstore
}

#define macro SAFE_TRANSFER() = takes (3) returns (0) {
    // stack: [amount, to, token]
    0xa9059cbb00000000000000000000000000000000000000000000000000000000 0x00 mstore
    dup2 0x04 mstore
    dup1 0x24 mstore
    0x20 0x00 0x44 0x00 0x00 dup8 gas call
    iszero transfer_failed jumpi
    returndatasize iszero transfer_success jumpi
    0x00 mload iszero transfer_failed jumpi
transfer_success:
    pop pop pop
    transfer_end jump
transfer_failed:
    0xbf182be800000000000000000000000000000000000000000000000000000000 0x00 mstore
    dup3 0x04 mstore
    dup2 0x24 mstore
    dup1 0x44 mstore
    0x64 0x00 revert
transfer_end:
}

#define macro SAFE_ALLOWANCE() = takes (2) returns (1) {
    // stack: [spender, token]
    0xdd62ed3e00000000000000000000000000000000000000000000000000000000 0x00 mstore
    address 0x04 mstore
    dup2 0x24 mstore
    0x20 0x00 0x44 0x00 dup5 gas staticcall
    iszero allowance_failed jumpi
    returndatasize 0x20 lt allowance_failed jumpi
    0x00 mload
    swap2 pop pop
    allowance_end jump
allowance_failed:
    0x1b6c83ab00000000000000000000000000000000000000000000000000000000 0x00 mstore
    dup2 0x04 mstore
    dup1 0x24 mstore
    0x44 0x00 revert
allowance_end:
}

#define macro SAFE_APPROVE() = takes (3) returns (0) {
    // stack: [amount, spender, token]
    0x095ea7b300000000000000000000000000000000000000000000000000000000 0x00 mstore
    dup2 0x04 mstore
    dup1 0x24 mstore
    0x20 0x00 0x44 0x00 0x00 dup8 gas call
    iszero approve_failed jumpi
    returndatasize iszero approve_success jumpi
    0x00 mload iszero approve_failed jumpi
approve_success:
    pop pop pop
    approve_end jump
approve_failed:
    0x1b6c83ab00000000000000000000000000000000000000000000000000000000 0x00 mstore
    dup3 0x04 mstore
    dup2 0x24 mstore
    0x44 0x00 revert
approve_end:
}

#define macro SAFE_APPROVE_MAX_IF_NEEDED() = takes (3) returns (0) {
    // stack: [amount, spender, token]
    dup2 dup4 SAFE_ALLOWANCE()
    dup2 dup2 lt iszero approve_max_needed_end jumpi
    dup2 iszero approve_zero_done jumpi
    dup4 dup4 0x00 SAFE_APPROVE()
approve_zero_done:
    dup4 dup4 0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff SAFE_APPROVE()
approve_max_needed_end:
    pop pop pop pop
}

#define macro TRANSFER_OWNERSHIP() = takes (0) returns (0) {
    ONLY_OWNER()
    0x04 calldataload
    dup1 iszero is_zero_revert jumpi
    0x00 sload
    dup2 0x00 sstore
    dup2 dup2
    0x8be0079c530c1b4141206c881090c54aec7decddc7d19f41692804f326b14eec
    0x00 0x00 log3
    pop pop
    stop
}

#define macro PRE_APPROVE() = takes (0) returns (0) {
    ONLY_OWNER()
    0x04 calldataload
    0x24 calldataload
    0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff
    dup3 dup3
    SAFE_APPROVE_MAX_IF_NEEDED()
    dup2 dup2
    0x0ca6fb6c483a93664d4b31a89c925828b8bb9b1285dbad851f503f8a4f91ef38
    0x00 0x00 log3
    pop pop
    stop
}

#define macro APPROVE_IF_NEEDED() = takes (0) returns (0) {
    caller address eq auth_ok jumpi
    caller 0x00 sload eq auth_ok jumpi
    0x82b42900 0x00 mstore
    0x04 0x1c revert
auth_ok:
    0x04 calldataload
    0x24 calldataload
    0x44 calldataload
    dup3 dup3 dup3
    SAFE_APPROVE_MAX_IF_NEEDED()
    pop pop pop
    stop
}

#define macro TRANSFER_ALL() = takes (0) returns (0) {
    caller address eq transfer_all_auth_ok jumpi
    caller 0x00 sload eq transfer_all_auth_ok jumpi
    0x82b42900 0x00 mstore
    0x04 0x1c revert
transfer_all_auth_ok:
    0x04 calldataload
    0x24 calldataload
    0x70a0823100000000000000000000000000000000000000000000000000000000 0x00 mstore
    address 0x04 mstore
    0x20 0x00 0x24 0x00 dup5 gas staticcall
    iszero transfer_all_balance_failed jumpi
    returndatasize 0x20 lt transfer_all_balance_failed jumpi
    0x00 mload
    dup1 iszero transfer_all_zero jumpi
    dup2 dup4 SAFE_TRANSFER()
    pop pop
    stop
transfer_all_zero:
    pop pop pop
    stop
transfer_all_balance_failed:
    0x00 0x00 revert
}

#define macro RESCUE_TOKEN() = takes (0) returns (0) {
    ONLY_OWNER()
    NON_REENTRANT()
    0x04 calldataload
    0x24 calldataload
    0x44 calldataload
    dup2 iszero is_zero_revert jumpi
    dup3 dup3 dup3 SAFE_TRANSFER()
    dup3 0x00 mstore
    dup2 dup2
    0x4143f7b5cb6ea007914c32b8a3e64cebc051d7f493fa0755454da1e47701e125
    0x20 0x00 log3
    pop pop pop
    REENTRANCY_GUARD_RELEASE()
    stop
}

#define macro RESCUE_NATIVE() = takes (0) returns (0) {
    ONLY_OWNER()
    NON_REENTRANT()
    0x04 calldataload
    0x24 calldataload
    dup2 iszero is_zero_revert jumpi
    0x00 0x00 0x00 0x00 dup5 dup5 gas call
    iszero native_rescue_failed jumpi
