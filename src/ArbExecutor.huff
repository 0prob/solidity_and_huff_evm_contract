direct_profit_done:
    0x00 0x02 sstore
    0x00 0x03 sstore
    0x00 0x04 sstore
    0x00 0x05 sstore

    dup1 0x80 mstore
    0x07 sload 0xa0 mstore
    0xa4 calldataload
    0x84 calldataload
    caller
    0x2790eac69d46d24bb29b55a23b12e2e49076dc2a9fdcb340e641de33fca2c5dd
    0x40 0x80
    log4
    pop
    0x20 0x80 return
deadline_expired:
