phase_idle_ok:
    0x44
    dup1 0x80 add calldataload timestamp gt deadline_expired jumpi
    dup1 0xc0 add dup1 calldataload
    dup1 iszero empty_route jumpi
    0x0c lt too_many_calls jumpi
    0x84 calldataload iszero zero_address jumpi

    0xc0 0x24 calldataload sub
