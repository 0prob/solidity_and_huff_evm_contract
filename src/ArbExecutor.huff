    0x01 0x06 sstore

    constructor_end jump
is_zero_revert:
    0xd92e233d00000000000000000000000000000000000000000000000000000000 0x00 mstore
    0x04 0x00 revert
constructor_end:
    // Init layout: [CONSTRUCTOR][args (0x220)][MAIN]. Return runtime for on-chain CREATE.
    codesize
    0x368
    sub
    0x368
    0x00
    codecopy
    codesize
    0x368
    sub
    0x00
    return
}

