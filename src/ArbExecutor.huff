    0x42b0b77c00000000000000000000000000000000000000000000000000000000 0x80 mstore
    address 0x84 mstore
    0x44 calldataload 0xa4 mstore
    0x64 calldataload 0xc4 mstore
    0xa0 0xe4 mstore
    0x00 0x104 mstore

