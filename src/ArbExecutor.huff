#define macro RECEIVE_FLASH_LOAN() = takes (0) returns (0) {
    // stack in: []  stack out: []
    caller 0x07 sload eq balancer_sender_ok jumpi
    0xfc305329 0x00 mstore
    0x04 0x1c revert
balancer_sender_ok:
    0x01 sload 0x01 eq phase_flashloan_ok jumpi
    0xadd4adc0 0x00 mstore
    0x04 0x1c revert
phase_flashloan_ok:
    0x64 calldataload 0x04 add
    0x20 add
    dup1 0xa0 add calldataload 0x02 sload eq route_hash_ok jumpi
    0xc858adff 0x00 mstore
    0x04 0x1c revert
route_hash_ok:
    dup1 0x40 add calldataload 0x03 sload eq profit_token_ok jumpi
    0xadd4adc0 0x00 mstore
    0x04 0x1c revert
profit_token_ok:
    dup1 0x60 add calldataload 0x04 sload eq min_profit_ok jumpi
    0xadd4adc0 0x00 mstore
    0x04 0x1c revert
min_profit_ok:
    dup1 0x80 add calldataload timestamp gt deadline_expired jumpi

    0x02 0x01 sstore                               // phase=2
    0xc0 add                                        // [calls_ptr]
    dup1 VALIDATE_NO_VAULT_CALLS()
    EXECUTE_CALLS()                                 // []

    0x04 calldataload 0x04 add                      // [tokens_ptr]
    0x24 calldataload 0x04 add                      // [amounts_ptr, tokens_ptr]
    0x44 calldataload 0x04 add                      // [premiums_ptr, amounts_ptr, tokens_ptr]
    dup3 calldataload                               // [num_tokens, premiums_ptr, amounts_ptr, tokens_ptr]
    0x00
repay_loop:
    dup2 dup2 eq repay_done jumpi
    dup1 0x20 mul 0x20 add
    dup6 dup2 add calldataload                      // [token]
    dup6 dup3 add calldataload                      // [amount, token]
    dup6 dup4 add calldataload                      // [premium, amount, token]
    add                                             // [repay = amount + premium, token]
    0x07 sload                                      // [balancerVault, repay, token]
    swap1                                           // [repay, balancerVault, token]
    SAFE_TRANSFER()                                 // [num_tokens, ...]
    pop
    0x01 add
    repay_loop jump
repay_done:
    pop pop pop pop pop
    0x00 0x01 sstore                                 // phase=0
    ASSERT_PROFIT()
    stop
deadline_expired:
    0x1ab7da6b 0x00 mstore
    0x04 0x1c revert
}

#define macro EXECUTE_OPERATION() = takes (0) returns (0) {
    caller 0x0c sload eq aave_sender_ok jumpi
