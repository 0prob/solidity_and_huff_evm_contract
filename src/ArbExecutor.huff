    GET_SLOT(0x0d)
uniswap_v2_factory_dest:
    GET_SLOT(0x0e)
sushi_v2_factory_dest:
    GET_SLOT(0x0f)
quickswap_v2_factory_dest:
    GET_SLOT(0x10)
quickswap_v4_factory_dest:
