    0x1c0 mload iszero is_zero_revert jumpi
    0x1e0 mload iszero is_zero_revert jumpi
    0x200 mload iszero is_zero_revert jumpi

    0x00 mload 0x00 sstore
    0x20 mload 0x07 sstore
    0x40 mload 0x08 sstore
    0x60 mload 0x09 sstore
    0x80 mload 0x0a sstore
    0xa0 mload 0x0b sstore
    0xc0 mload 0x0c sstore
    0xe0 mload 0x0d sstore
    0x100 mload 0x0e sstore
