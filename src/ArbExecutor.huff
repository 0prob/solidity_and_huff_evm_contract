#define macro VALIDATE_NO_VAULT_CALLS() = takes (1) returns (0) {
    // Reject routes that call the Balancer Vault during a Vault flash-loan callback.
    dup1 calldataload
    swap1 0x20 add
    0x00
validate_vault_loop:
    dup1 dup4 eq validate_vault_done jumpi
    dup2 calldataload
    dup1 0x07 sload eq validate_vault_revert jumpi
    dup2 0x40 add calldataload
    dup1 dup4 add 0x60 add
    0x00 mstore
    pop
    swap1 pop
    0x01 add
    0x00 mload swap1
    validate_vault_loop jump
validate_vault_revert:
    0x6be92da6 0x00 mstore
    0x04 0x1c revert
validate_vault_done:
    pop pop pop
}

#define macro EXECUTE_CALLS() = takes (1) returns (0) {
    // Packed layout: count, then repeated target/value/dataLen/data.
    dup1 calldataload
    swap1 0x20 add
    0x00
execute_calls_loop:
    dup1 dup4 eq execute_calls_done jumpi
    dup2 calldataload
    dup3 0x20 add calldataload
    dup4 0x40 add calldataload
    dup3 0x80 mstore
    dup2 0xa0 mstore
    dup1 dup6 0x60 add 0x100 calldatacopy
    0x00 0x00 dup3 0x100 0xa0 mload 0x80 mload gas call
    iszero execute_call_failed jumpi
    swap2 pop pop
    dup1 dup4 add 0x60 add
    0x00 mstore
    pop
    swap1 pop
    0x01 add
    0x00 mload swap1
    execute_calls_loop jump
execute_call_failed:
    0x0f43457300000000000000000000000000000000000000000000000000000000 0x00 mstore
    dup6 0x04 mstore
    dup4 0x24 mstore
    0x60 0x44 mstore
    returndatasize 0x64 mstore
    returndatasize 0x00 0x84 returndatacopy
    returndatasize 0x84 add 0x00 revert
execute_calls_done:
    pop pop pop
}

#define macro ASSERT_PROFIT() = takes (0) returns (0) {
    0x03 sload
    0x70a0823100000000000000000000000000000000000000000000000000000000 0x00 mstore
    address 0x04 mstore
    0x20 0x00 0x24 0x00 dup5 gas staticcall
    iszero assert_balance_failed jumpi
    returndatasize 0x20 lt assert_balance_failed jumpi
    0x00 mload
    0x05 sload 0x04 sload add
    dup2 dup2 gt iszero assert_profit_ok jumpi
    0x4e88422a00000000000000000000000000000000000000000000000000000000 0x00 mstore
    swap1 0x04 mstore
    0x24 mstore
    0x44 0x00 revert
assert_profit_ok:
    pop pop
    assert_profit_end jump
assert_balance_failed:
    0x00 0x00 revert
assert_profit_end:
}

#define macro EXECUTE_ARB() = takes (0) returns (0) {
    // stack in: []  stack out: []
    ONLY_OWNER()
    0x01 sload iszero phase_idle_ok jumpi
    0xadd4adc0 0x00 mstore
    0x04 0x1c revert
phase_idle_ok:
    0x44                                             // [params_ptr]
    dup1 0x80 add calldataload timestamp gt deadline_expired jumpi
    dup1 0xc0 add dup1 calldataload                   // [params_ptr, calls_ptr, num_calls]
    dup1 iszero empty_route jumpi
    0x0c lt too_many_calls jumpi
    0x64 calldataload iszero flash_loan_required jumpi
    0x44 calldataload iszero zero_address jumpi
    0x84 calldataload iszero zero_address jumpi
    0xc0 0x24 calldataload sub                      // [calls_bytes_len, params_ptr, calls_ptr, num_calls]
    dup1 0x00 mstore                                // store calls_bytes_len at mem[0x00]
    dup1 0x104 0x20 calldatacopy                    // copy packed calls to mem[0x20]
    dup1 0x20 sha3                                  // keccak256(mem[0x20:0x20+calls_bytes_len])
    0xe4 calldataload                               // [expected_hash, hash, params_ptr, calls_ptr, num_calls]
    eq route_hash_ok jumpi
    0xc858adff 0x00 mstore
    0x04 0x1c revert
route_hash_ok:
    // stack: [params_ptr, calls_ptr, num_calls]
    0x84 calldataload                               // [profitToken, params_ptr, calls_ptr, num_calls]
    0x70a0823100000000000000000000000000000000000000000000000000000000 0x00 mstore
    address 0x04 mstore
    0x20 0x00 0x24 0x00 dup5 gas staticcall          // [success, profitToken, ...]
    iszero balance_failed jumpi
    returndatasize 0x20 lt balance_failed jumpi
    0x00 mload                                       // [balance, profitToken, params_ptr, calls_ptr, num_calls]
    dup1 0x05 sstore                                 // starting profit-token balance

    0x01 0x01 sstore                                 // phase=1
    0xe4 calldataload 0x02 sstore                    // routeHash
    0x84 calldataload 0x03 sstore                    // profitToken
    0xa4 calldataload 0x04 sstore                    // minProfit

    0x5c38449e00000000000000000000000000000000000000000000000000000000 0x80 mstore
    address 0x84 mstore
    0x80 0xa4 mstore
    0xc0 0xc4 mstore
    0x100 0xe4 mstore
    0x01 0x104 mstore
    0x44 calldataload 0x124 mstore
    0x01 0x144 mstore
    0x64 calldataload 0x164 mstore

    0x24 calldataload
    dup1 0x184 mstore
    dup1 0x44 0x1a4 calldatacopy
    0x124 add
    0x00 0x00 swap2 0x80 0x00 0x07 sload gas call
    iszero balancer_call_failed jumpi

    0x01 sload iszero phase_idle_after_ok jumpi
    0xadd4adc0 0x00 mstore
    0x04 0x1c revert
phase_idle_after_ok:
    dup2
    0x70a0823100000000000000000000000000000000000000000000000000000000 0x00 mstore
    address 0x04 mstore
    0x20 0x00 0x24 0x00 dup5 gas staticcall
    iszero balance_failed jumpi
    returndatasize 0x20 lt balance_failed jumpi
    0x00 mload
    
    dup2 dup2 lt iszero profit_calc jumpi
    0x00
    profit_done jump
profit_calc:
    dup2 dup2 sub
profit_done:
    0x00 0x01 sstore
    0x00 0x02 sstore
    0x00 0x03 sstore
    0x00 0x04 sstore
    0x00 0x05 sstore

    dup1 0x80 mstore
    0x07 sload 0xa0 mstore

    dup6 0x60 add calldataload
    dup5
    caller
    0x2790eac69d46d24bb29b55a23b12e2e49076dc2a9fdcb340e641de33fca2c5dd
    0x40 0x80
    log4
    pop pop pop pop pop
    0x20 0x80 return
deadline_expired:
    0x1ab7da6b 0x00 mstore
    0x04 0x1c revert
empty_route:
    0xea60ab1d 0x00 mstore
    0x04 0x1c revert
too_many_calls:
    0xf5dedbff 0x00 mstore
    0x04 0x1c revert
flash_loan_required:
    0x946302fe 0x00 mstore
    0x04 0x1c revert
zero_address:
    0xd92e233d 0x00 mstore
    0x04 0x1c revert
balance_failed:
    0x00 0x00 revert
balancer_call_failed:
    returndatasize 0x00 0x00 returndatacopy
    returndatasize 0x00 revert
}

