    0x00 0x04 mstore
    dup2 0x24 mstore
    dup1 0x44 mstore
    0x64 0x00 revert
}

#define macro WITHDRAW() = takes (0) returns (0) {
    ONLY_OWNER()
    selfbalance
    dup1 iszero withdraw_zero jumpi
    0x00 sload
    swap1
    0x00 0x00 0x00 0x00
    dup4 dup5
    gas
    call
    iszero withdraw_failed jumpi
    pop pop
    stop
withdraw_zero:
    pop
    stop
withdraw_failed:
    0xbf182be800000000000000000000000000000000000000000000000000000000 0x00 mstore
    0x00 0x04 mstore
    dup1 0x24 mstore
    dup1 0x44 mstore
    0x64 0x00 revert
}

#define macro WITHDRAW_TOKEN() = takes (0) returns (0) {
    ONLY_OWNER()
    0x04 calldataload
    dup1 iszero is_zero_revert jumpi
    0x70a0823100000000000000000000000000000000000000000000000000000000 0x00 mstore
    address 0x04 mstore
    0x20 0x00 0x24 0x00 dup5 gas staticcall
    iszero wtoken_bal_failed jumpi
    returndatasize 0x20 lt wtoken_bal_failed jumpi
    0x00 mload
    dup1 iszero wtoken_skip jumpi
    0x00 sload
    0xa9059cbb00000000000000000000000000000000000000000000000000000000 0xe0 mstore
    dup2 0xe4 mstore
    dup3 0x104 mstore
    0x20 0x00 0x44 0xe0 0x00 dup6 gas call
    iszero wtoken_xfer_failed jumpi
    returndatasize iszero wtoken_xfer_ok jumpi
    0x00 mload iszero wtoken_xfer_failed jumpi
wtoken_xfer_ok:
    pop pop pop
    stop
wtoken_skip:
