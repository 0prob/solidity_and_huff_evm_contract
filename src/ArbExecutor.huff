}

#define macro HANDLE_POOL_SWAP_CALLBACK(protocolId) = takes (0) returns (0) {
    0x01 sload 0x02 eq callback_phase_ok jumpi
    0xc21d53e8 0x00 mstore
    0x04 0x1c revert
callback_phase_ok:
    0x44 calldataload 0x04 add
