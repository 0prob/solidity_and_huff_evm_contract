    0x20 0x00 0x24 0x00 dup5 gas staticcall
    iszero balance_failed jumpi
    returndatasize 0x20 lt balance_failed jumpi
    0x00 mload
    dup1 0x05 sstore

    0x02 0x01 sstore
    0xe4 calldataload 0x02 sstore
    0x84 calldataload 0x03 sstore
    0xa4 calldataload 0x04 sstore

    0xc0 add
    EXECUTE_CALLS()

    0x00 0x01 sstore
    ASSERT_PROFIT()

    0x03 sload
    0x70a0823100000000000000000000000000000000000000000000000000000000 0x00 mstore
    address 0x04 mstore
    0x20 0x00 0x24 0x00 dup5 gas staticcall
    iszero balance_failed jumpi
    returndatasize 0x20 lt balance_failed jumpi
    0x00 mload
    0x05 sload
