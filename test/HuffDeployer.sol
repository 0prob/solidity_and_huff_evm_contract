pragma solidity ^0.8.34;

library HuffDeployer {
    bytes constant BYTECODE = hex"";

    function concatInit(bytes memory a, bytes memory b, bytes memory c) internal pure returns (bytes memory) {
        return abi.encodePacked(a, b, c);
    }
    function concatInit2(bytes memory a, bytes memory b) internal pure returns (bytes memory) {
        return abi.encodePacked(a, b);
    }

    function encode1(address a0, address a1, address a2, address a3, address a4, address a5, address a6, address a7) internal pure returns (bytes memory) {
        return abi.encode(a0, a1, a2, a3, a4, a5, a6, a7);
    }
    function encode2(address a0, address a1, address a2, address a3, address a4, address a5, address a6, address a7, address a8) internal pure returns (bytes memory) {
        return abi.encode(a0, a1, a2, a3, a4, a5, a6, a7, a8);
    }
}
